{
  "name": "@telegram/app",
  "version": "0.0.1",
  "private": true,
  "description": "Telegram Mini App",
  "keywords": [
    "telegram",
    "mini",
    "app"
  ],
  "homepage": "https://hieudoanm.github.io/telegram",
  "bugs": {
    "url": "https://github.com/hieudoanm/telegram/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/hieudoanm/telegram.git"
  },
  "license": "GPL-3.0",
  "author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "25.9.0"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "format": "prisma format && prettier --cache --write .",
    "prisma:generate": "prisma format && prisma generate",
    "prelint": "pnpm prisma:generate",
    "predev": "pnpm prisma:generate && kill-port 3000",
    "dev": "next dev --turbopack",
    "pretest": "pnpm prisma:generate && rimraf coverage && jest --clearCache",
    "test": "jest",
    "prebuild": "pnpm prisma:generate && rimraf .next ../../docs",
    "build": "next build --turbopack",
    "postbuild": "bash ./scripts/sh/post-build.sh",
    "prestart": "pnpm prisma:generate && kill-port 3000",
    "start": "next start",
    "tauri": "tauri",
    "dev:desktop": "tauri dev",
    "build:desktop": "tauri build"
  },
  "dependencies": {
    "@capacitor/android": "8.3.1",
    "@capacitor/core": "8.3.1",
    "@capacitor/ios": "8.3.1",
    "@prisma/client": "7.8.0",
    "@tanstack/react-query": "5.99.2",
    "@tauri-apps/api": "2.10.1",
    "@ton/core": "0.63.1",
    "@ton/crypto": "3.3.0",
    "@ton/ton": "16.2.4",
    "@tonconnect/ui-react": "2.4.4",
    "@trpc/client": "11.16.0",
    "@trpc/next": "11.16.0",
    "@trpc/react-query": "11.16.0",
    "@trpc/server": "11.16.0",
    "buffer": "6.0.3",
    "cookie": "1.1.1",
    "jsonwebtoken": "9.0.3",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-icons": "5.6.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.1",
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.2.4",
    "@tauri-apps/cli": "2.10.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "30.0.0",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.2.1",
    "eslint-config-next": "16.2.4",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "kill-port": "2.0.1",
    "ngrok": "5.0.0-beta.2",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.8.0",
    "prisma-dbml-generator": "0.12.0",
    "prisma-json-schema-generator": "5.1.5",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.4",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
