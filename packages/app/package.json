{
	"name": "@telegram/app",
	"version": "0.0.1",
	"private": true,
	"description": "Telegram Mini App",
	"keywords": [
		"telegram",
		"mini",
		"app"
	],
	"homepage": "https://hieudoanm.github.io/tg",
	"bugs": {
		"url": "https://github.com/hieudoanm/tg/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/hieudoanm/tg.git"
	},
	"license": "GPL-3.0",
	"author": "hieudoanm <hieumdoan@gmail.com> (https://hieudoanm.github.io)",
	"packageManager": "pnpm@10.30.2",
	"scripts": {
		"format": "prisma format && prettier --cache --write .",
		"prisma:generate": "prisma format && prisma generate",
		"prelint": "pnpm prisma:generate",
		"lint": "eslint .",
		"predev": "pnpm prisma:generate && kill-port 3000",
		"dev": "next dev",
		"prebuild": "pnpm prisma:generate && rimraf .next ../../docs",
		"build": "next build",
		"postbuild": "touch ../../docs/.nojekyll",
		"prestart": "pnpm prisma:generate && kill-port 3000",
		"start": "next start",
		"pretest": "pnpm prisma:generate && rimraf coverage",
		"test": "jest"
	},
	"dependencies": {
		"@prisma/client": "7.4.1",
		"@tanstack/react-query": "5.90.21",
		"@ton/core": "0.63.1",
		"@ton/crypto": "3.3.0",
		"@ton/ton": "16.2.2",
		"@tonconnect/ui-react": "2.4.2",
		"@trpc/client": "11.10.0",
		"@trpc/next": "11.10.0",
		"@trpc/react-query": "11.10.0",
		"@trpc/server": "11.10.0",
		"buffer": "6.0.3",
		"cookie": "1.1.1",
		"jsonwebtoken": "9.0.3",
		"next": "16.1.6",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-icons": "5.5.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.4",
		"@tailwindcss/postcss": "4.2.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/jest": "30.0.0",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "25.3.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"eslint": "9.39.3",
		"eslint-config-next": "16.1.6",
		"husky": "9.1.7",
		"jest": "30.2.0",
		"jest-environment-jsdom": "30.2.0",
		"kill-port": "2.0.1",
		"ngrok": "5.0.0-beta.2",
		"prettier": "3.8.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"prisma": "7.4.1",
		"rimraf": "6.1.3",
		"tailwindcss": "4.2.1",
		"ts-jest": "29.4.6",
		"ts-node": "10.9.2",
		"typescript": "5.9.3"
	}
}
